{
  "name": "teta-ai-assistant",
  "version": "0.0.1",
  "private": true,
  "description": "Teta AI Assistant — intranetowy asystent AI (React + NestJS + Ollama + Qdrant)",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "build:client": "pnpm --filter @teta/shared run build && pnpm --filter @teta/api run build:client && pnpm --filter @teta/web run build",
    "build:vendor": "pnpm --filter @teta/shared run build && pnpm --filter @teta/api run build:vendor && pnpm --filter @teta/web run build",
    "dev:api": "pnpm --filter @teta/api run dev",
    "dev:web": "pnpm --filter @teta/web run dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm --filter @teta/api run test",
    "rag:global:ingest": "pnpm --filter @teta/api run rag:global:ingest",
    "rag:global:import-chunks": "pnpm --filter @teta/api run rag:global:import-chunks",
    "rag:global:export": "pnpm --filter @teta/api run rag:global:export",
    "rag:global:import": "pnpm --filter @teta/api run rag:global:import",
    "rag:validate-chunks": "pnpm --filter @teta/api run rag:validate-chunks",
    "rag:video:ingest": "pnpm --filter @teta/api run rag:video:ingest",
    "setup:install": "powershell -ExecutionPolicy Bypass -File scripts/setup/Setup.ps1",
    "setup:vendor": "powershell -ExecutionPolicy Bypass -File scripts/setup/Setup.ps1 -Mode vendor",
    "setup:client": "powershell -ExecutionPolicy Bypass -File scripts/setup/Setup.ps1 -Mode client",
    "setup:client:offline": "powershell -ExecutionPolicy Bypass -File scripts/setup/Setup.ps1 -Mode client -Offline",
    "bundle:offline": "powershell -ExecutionPolicy Bypass -File scripts/setup/Prepare-OfflineBundle.ps1",
    "postinstall": "pnpm --filter @teta/shared run build"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.28.1"
}
