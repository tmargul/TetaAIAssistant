{
  "name": "@teta/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node scripts/prepare-build-profile.mjs vendor && pnpm --filter @teta/shared run build && nest build",
    "build:client": "node scripts/prepare-build-profile.mjs client && pnpm --filter @teta/shared run build && nest build -p tsconfig.build.client.json && node scripts/prepare-build-profile.mjs vendor",
    "build:vendor": "node scripts/prepare-build-profile.mjs vendor && pnpm --filter @teta/shared run build && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "rag:global:ingest": "ts-node -r tsconfig-paths/register src/scripts/rag-global-cli.ts ingest",
    "rag:global:import-chunks": "ts-node -r tsconfig-paths/register src/scripts/rag-global-cli.ts import-chunks",
    "rag:global:export": "ts-node -r tsconfig-paths/register src/scripts/rag-global-cli.ts export",
    "rag:global:import": "ts-node -r tsconfig-paths/register src/scripts/rag-import-cli.ts import",
    "rag:validate-chunks": "ts-node -r tsconfig-paths/register src/scripts/rag-validate-chunks-cli.ts validate",
    "rag:video:ingest": "ts-node -r tsconfig-paths/register src/scripts/rag-video-cli.ts ingest"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@teta/shared": "workspace:*",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.10.0",
    "extract-zip": "^2.0.1",
    "fast-xml-parser": "^5.10.0",
    "html-to-text": "^10.0.0",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "oracledb": "^7.0.0",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
