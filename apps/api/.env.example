PORT=3000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=file:./data/teta.sqlite
JWT_SECRET=dev-local-jwt-secret-min-32-chars!!
JWT_EXPIRES_IN=7d
# vendor = budowa globalnego RAG u Tety, client = instalacja u klienta
TETA_APP_MODE=client
# Tylko u Tety (gdy TETA_APP_MODE=vendor). Min. 32 znaki, losowy klucz. NIE wdrażać u klienta.
# TETA_VENDOR_SECRET=
# Oracle Teta: fake = symulator (dev), real = prawdziwa baza
TETA_ORACLE_MODE=fake
# Konta testowe (tylko gdy TETA_ORACLE_MODE=fake)
TETA_FAKE_ADMIN_USER=teta_admin
TETA_FAKE_ADMIN_PASSWORD=admin
TETA_FAKE_USER=teta_user
TETA_FAKE_USER_PASSWORD=user
# Zapytanie weryfikujące administratora Teta (tylko gdy TETA_ORACLE_MODE=real)
TETA_ADMIN_CHECK_SQL=SELECT 1 AS is_admin FROM DUAL WHERE 1=0
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_CHAT=qwen3
OLLAMA_MODEL_REASONING=deepseek-r1
# qwen3: domyślnie think=false w API (szybsze odpowiedzi). deepseek-r1 używa thinking.
# OLLAMA_CHAT_THINK=false
OLLAMA_CHAT_TIMEOUT_MS=180000
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSIONS=768
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_GLOBAL=teta_global
QDRANT_COLLECTION_CLIENT=teta_client
# Ingest wideo MP4 → RAG (CLI: pnpm rag:video:ingest)
# TETA_VIDEO_CHUNK_SECONDS=180
# TETA_VIDEO_FRAMES_PER_CHUNK=3
# TETA_WHISPER_MODEL=large-v3-turbo
# TETA_WHISPER_LANGUAGE=pl
# TETA_WHISPER_DEVICE=auto
# TETA_FFMPEG_PATH=ffmpeg
# TETA_FFPROBE_PATH=ffprobe
# Po winget install Gyan.FFmpeg — pełne ścieżki, jeśli API nie widzi PATH (wymaga restartu procesu):
# TETA_FFMPEG_PATH=C:\Users\<user>\AppData\Local\Microsoft\WinGet\Packages\...\bin\ffmpeg.exe
# TETA_FFPROBE_PATH=C:\Users\<user>\AppData\Local\Microsoft\WinGet\Packages\...\bin\ffprobe.exe
# TETA_PYTHON=python
# TETA_VIDEO_MAX_UPLOAD_BYTES=8589934592
# TETA_VIDEO_UPLOAD_DIR=data/video-ingest/uploads
# Katalog plików dokumentów klienta (RAG lokalny)
RAG_DOCUMENTS_DIR=data/rag-documents
RAG_DOCUMENT_MAX_BYTES=10485760
RAG_CHAT_TOP_K=4
