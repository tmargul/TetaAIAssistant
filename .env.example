# Skopiuj do apps/api/.env i dostosuj wartości.

# API
PORT=3000
CORS_ORIGIN=http://localhost:5173

# SQLite (ścieżka względem apps/api)
DATABASE_URL=file:./data/teta.sqlite

# JWT (wygeneruj silny sekret na produkcji klienta)
JWT_SECRET=dev-local-jwt-secret-min-32-chars!!
JWT_EXPIRES_IN=7d

# Ollama (lokalnie na serwerze klienta)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_CHAT=qwen3
OLLAMA_MODEL_REASONING=deepseek-r1

# Qdrant (natywna instalacja na serwerze klienta — bez Dockera)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=teta_documents
